<%=
  render(Primer::Box.new(display: :flex, align_items: :center, justify_content: :center, style: "min-height: 70vh;")) do
    render(OpPrimer::FullPagePromptComponent.new) do |prompt|
      prompt.with_icon(icon: :question, color: :accent)
      prompt.with_title { "Full page prompt" }
      prompt.with_action_button(tag: :button, scheme: :primary) { "Continue" }

      render(Primer::Box.new(color: :muted)) do
        concat render(Primer::Beta::Text.new) { "Use this component for a fullscreen, dialog-like prompt." }
        concat render(Primer::Beta::Text.new(tag: :p, mb: 0, mt: 2)) { "Keep content short and action-oriented." }
      end
    end
  end
%>

