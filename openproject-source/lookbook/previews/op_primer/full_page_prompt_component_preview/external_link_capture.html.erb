<%=
  render(Primer::Box.new(display: :flex, align_items: :center, justify_content: :center, style: "min-height: 70vh;")) do
    render(OpPrimer::FullPagePromptComponent.new) do |prompt|
      prompt.with_icon(icon: :alert, color: :danger)
      prompt.with_title { "You are leaving OpenProject" }

      prompt.with_action_button(
        tag: :a,
        flex: 1,
        href: external_url,
        scheme: :danger,
        data: { turbo: false }
      ) { "Continue to external website" }

      render(Primer::Box.new(color: :muted)) do
        concat render(Primer::Beta::Text.new) { "This link points to an external website. OpenProject cannot verify its content." }
        concat render(Primer::Beta::Text.new(tag: :p, mb: 0, mt: 2)) { "Only continue if you trust the destination:" }
        concat render(Primer::Beta::Text.new(tag: :p, font_weight: :bold)) { external_url }
      end
    end
  end
%>
