<%= render(
      OpPrimer::QuickFilter::SegmentedComponent.new(
        name: "Time",
        query: query,
        filter_key: :time,
        orders: { "future" => { start_time: :asc }, "past" => { start_time: :desc } },
        path_args: [:meetings]
      )
    ) do |component|
      component.with_item(label: "Upcoming", value: "future")
      component.with_item(label: "Past", value: "past")
    end %>
