<%=
  render(Primer::Alpha::Dialog.new(title:, size: :medium_portrait, id: DIALOG_ID)) do |d|
    d.with_header(variant: :large)

    d.with_body do
      render(
        ResourcePlanners::FormComponent.new(
          resource_planner: @resource_planner,
          project: @project
        )
      )
    end

    d.with_footer do
      component_collection do |buttons|
        buttons.with_component(
          Primer::Beta::Button.new(
            data: { close_dialog_id: DIALOG_ID }
          )
        ) do
          t("button_cancel")
        end

        buttons.with_component(
          Primer::Beta::Button.new(
            scheme: :primary,
            form: FORM_ID,
            data: { turbo: true },
            type: :submit
          )
        ) do
          t("button_next")
        end
      end
    end
  end
%>
