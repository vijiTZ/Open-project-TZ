<%=
  component_wrapper do
    grid_layout("op-storage-view--row", tag: :div, align_items: :center) do |grid|
      grid.with_area(:item, tag: :div, mr: 3) do
        concat(render(Primer::Beta::Text.new(font_weight: :bold, mr: 1)) { t("wikis.admin.wiki_providers.#{wiki_provider}.oauth.provider_oauth") })
        if oauth_client.present?
          concat(render(Primer::Beta::Label.new(scheme: :success)) { t(:label_completed) })
        else
          concat(render(Primer::Beta::Label.new(scheme: :secondary)) { t(".label_pending") })
        end
      end

      grid.with_area(:description, tag: :div, color: :subtle) do
        render(Primer::Beta::Text.new) { t("wikis.admin.wiki_providers.#{wiki_provider}.oauth.provider_oauth_description") }
      end

      if wiki_provider.persisted?
        grid.with_area(:"icon-button", tag: :div, color: :muted) do
          flex_layout(justify_content: :flex_end) do |icons|
            icons.with_column do
              data_options = { turbo_stream: true }
              data_options[:turbo_confirm] = t(".confirm_replace_oauth_client") if oauth_client.present?

              icon_button_options = {
                icon: oauth_client.present? ? :sync : :pencil,
                scheme: :invisible,
                tag: :a,
                href: url_helpers.new_admin_settings_wiki_provider_oauth_client_path(wiki_provider),
                aria: { label: t(".replace_oauth_client") },
                data: data_options
              }
              render(Primer::Beta::IconButton.new(**icon_button_options))
            end
          end
        end
      end
    end
  end
%>
