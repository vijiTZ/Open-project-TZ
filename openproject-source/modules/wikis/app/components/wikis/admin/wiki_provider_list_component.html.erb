<%=
  if wiki_providers.present?
    render(border_box_container) do |component|
      component.with_header(color: :muted) do
        grid_layout("op-wiki-provider-list--header", tag: :div, align_items: :center) do |grid|
          grid.with_area(:name, tag: :div, mr: 3) do
            render(Primer::Beta::Text.new(font_weight: :semibold)) { t(".label_name") }
          end

          grid.with_area(:provider, tag: :div, color: :muted, mr: 3, hide: :sm) do
            render(Primer::Beta::Text.new(font_weight: :semibold)) { t(".label_provider") }
          end

          grid.with_area(:time, tag: :div, color: :muted, hide: :sm) do
            render(Primer::Beta::Text.new(font_weight: :semibold)) { t(".label_creation_time") }
          end
        end
      end

      wiki_providers.each do |wiki_provider|
        component.with_row(scheme: :default, id: helpers.dom_id(wiki_provider)) do
          grid_layout("op-wiki-provider-list--row", tag: :div) do |grid|
            grid.with_area(:name, tag: :div, mr: 3) do
              concat(render(Primer::Beta::Link.new(
                href: url_helpers.edit_admin_settings_wiki_provider_path(wiki_provider),
                font_weight: :bold
              )) { wiki_provider.name })
              concat(render(Primer::Beta::Text.new(color: :muted, font_size: :small, display: :block)) { provider_url(wiki_provider) }) if provider_url(wiki_provider)
            end

            grid.with_area(:provider, tag: :div, color: :subtle, mr: 3, hide: :sm) do
              render(Primer::Beta::Text.new(color: :subtle)) { wiki_provider.model_name.human }
            end

            grid.with_area(:time, tag: :div, color: :subtle, hide: :sm) do
              render(Primer::Beta::Text.new(color: :subtle)) { t("activity.item.created_on", datetime: helpers.format_time(wiki_provider.created_at)).capitalize }
            end
          end
        end
      end
    end
  else
    render(Primer::Beta::Blankslate.new(border: true, test_selector: "wiki-providers-blank-slate")) do |blank_slate|
      blank_slate.with_visual_icon(icon: :browser)
      blank_slate.with_heading(tag: :h2).with_content(t(".no_results_title"))
      blank_slate.with_description { t(".no_results_description") }
    end
  end
%>
