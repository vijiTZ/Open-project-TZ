<%=
  render(
    Primer::Alpha::Dialog.new(
      id: "new-meeting-dialog",
      title:,
      size: :medium_portrait,
      data: { "keep-open-on-submit": true }
    )
  ) do |dialog|
    dialog.with_header(variant: :large)
    dialog.with_body(classes: "Overlay-body_autocomplete_height") do
      render(
        Meetings::Index::FormComponent.new(
          meeting: @meeting,
          project: @project,
          copy_from: @copy_from,
          template: @template
        )
      )
    end

    dialog.with_footer do
      component_collection do |modal_footer|
        modal_footer.with_component(
          Primer::Beta::Button.new(
            data: { "close-dialog-id": "new-meeting-dialog" }
          )
        ) do
          I18n.t(:button_cancel)
        end

        modal_footer.with_component(
          Primer::Beta::Button.new(
            scheme: :primary,
            form: "meeting-form",
            type: :submit
          )
        ) do
          submit_button_text
        end
      end
    end
  end
%>
