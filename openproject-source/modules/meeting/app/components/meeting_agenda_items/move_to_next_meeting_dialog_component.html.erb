<%=
  render(
    Primer::Alpha::Dialog.new(
      title: title,
      id: "move-to-next-meeting-dialog",
      size: :medium_portrait
    )
  ) do |dialog|
    dialog.with_header(variant: :large)
    dialog.with_body(classes: "Overlay-body_autocomplete_height--lg") do
      concat(render(Primer::Alpha::Banner.new(scheme: :warning, mb: 3)) { simple_format(confirmation_message) })
      concat(
        render(
          MeetingAgendaItems::MoveToNextMeetingFormComponent.new(
            agenda_item: @agenda_item,
            datetime: @datetime,
            next_occurrence: @next_occurrence
          )
        )
      )
    end
    dialog.with_footer do
      component_collection do |buttons|
        buttons.with_component(
          Primer::Beta::Button.new(
            data: { "close-dialog-id": "move-to-next-meeting-dialog" }
          )
        ) do
          t("button_cancel")
        end
        buttons.with_component(
          Primer::Beta::Button.new(
            scheme: :danger,
            form: "move-to-next-meeting-form",
            data: { turbo: true },
            type: :submit
          )
        ) do
          I18n.t(:label_agenda_item_move)
        end
      end
    end
  end
%>
