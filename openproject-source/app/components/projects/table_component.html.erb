<%= component_wrapper(tag: "turbo-frame") do %>
  <style>
    .op-project-cards-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      padding: 16px 0;
    }
    .op-project-card {
      background: #ffffff;
      border: 1px solid #e4e8f0;
      border-radius: 12px;
      padding: 20px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.05);
      transition: box-shadow 0.2s ease, border-color 0.2s ease;
      display: flex;
      flex-direction: column;
      gap: 10px;
      position: relative;
    }
    .op-project-card:hover {
      box-shadow: 0 4px 16px rgba(0,0,0,0.10);
      border-color: #c8d0e0;
    }
    .op-project-card--header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 8px;
    }
    .op-project-card--name-wrap {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      flex: 1;
      min-width: 0;
    }
    .op-project-card--name a {
      font-size: 15px;
      font-weight: 600;
      color: #1a1a2e;
      text-decoration: none;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      display: block;
    }
    .op-project-card--name a:hover { color: #1f77b8; }
    .op-project-card--badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 11px;
      font-weight: 500;
      padding: 3px 10px;
      border-radius: 20px;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .op-project-card--badge.-active  { background: #e8f8f0; color: #1a7f4b; }
    .op-project-card--badge.-closed  { background: #fdecea; color: #c0392b; }
    .op-project-card--badge.-inactive { background: #f2f3f5; color: #6b7280; }
    .op-project-card--badge-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      display: inline-block;
      flex-shrink: 0;
    }
    .op-project-card--badge.-active  .op-project-card--badge-dot { background: #1a7f4b; }
    .op-project-card--badge.-closed  .op-project-card--badge-dot { background: #c0392b; }
    .op-project-card--badge.-inactive .op-project-card--badge-dot { background: #9ca3af; }
    .op-project-card--description {
      font-size: 13px;
      color: #6b7280;
      line-height: 1.55;
      min-height: 18px;
    }
    .op-project-card--actions { flex-shrink: 0; }
    @media (max-width: 1100px) { .op-project-cards-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 640px)  { .op-project-cards-grid { grid-template-columns: 1fr; } }
  </style>

  <div class="project-list-page--table" data-controller="table-action-menu">
    <% if rows.empty? %>
      <div style="padding: 40px 0; text-align: center; color: #6b7280;">
        <%= empty_row_message %>
      </div>
    <% else %>
      <div class="op-project-cards-grid">
        <%= render_collection rows %>
      </div>
    <% end %>
    <% if inline_create_link %>
      <div class="wp-inline-create-button">
        <%= inline_create_link %>
      </div>
    <% end %>
  </div>
  <% if paginated? %>
    <%= helpers.pagination_links_full(model, **pagination_options) %>
  <% end %>
<% end %>
