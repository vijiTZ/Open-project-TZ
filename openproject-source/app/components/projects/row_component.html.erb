<%
  if project.archived?
    badge_cls = "-closed";  badge_label = "Closed"
  elsif project.active?
    badge_cls = "-active";  badge_label = "Active"
  else
    badge_cls = "-inactive"; badge_label = "Inactive"
  end
  desc = helpers.strip_tags(project.description.to_s).strip.truncate(120)
%>
<div id="<%= row_css_id %>" class="op-project-card context-menu--reveal">
  <div class="op-project-card--header">
    <div class="op-project-card--name-wrap">
      <span class="op-project-card--name">
        <%= helpers.link_to_project(project, {}, { data: { turbo: false } }, false) %>
      </span>
      <span class="op-project-card--badge <%= badge_cls %>">
        <span class="op-project-card--badge-dot"></span>
        <%= badge_label %>
      </span>
    </div>
    <div class="op-project-card--actions">
      <% button_links.each do |link| %><%= link %><% end %>
    </div>
  </div>
  <div class="op-project-card--description"><%= desc %></div>
</div>
