<% html_title t(:label_administration), t(:label_workflow_plural) -%>

<%= render Workflows::PageHeaders::IndexComponent.new %>

<%=
  flex_layout data: { controller: "filter--filter-list", "filter--filter-list-clear-button-id-value": "type-filter-clear-button" } do |flex|
    flex.with_row do
      render(Primer::OpenProject::SubHeader.new) do |subheader|
        subheader.with_filter_input(
          name: "type-filter-input",
          label: t(".type_filter.label"),
          visually_hide_label: true,
          placeholder: t(".type_filter.label"),
          leading_visual: {
            icon: :search,
            size: :small
          },
          show_clear_button: true,
          clear_button_id: "type-filter-clear-button",
          data: {
            action: "input->filter--filter-list#filterLists",
            "filter--filter-list-target": "filter"
          }
        )
      end
    end

    flex.with_row do
      render Workflows::TableComponent.new(@types)
    end
  end
%>
